{
  "name": "claude-hub-new",
  "version": "0.1.0",
  "description": "Statusline HUD for Claude Code with a context-aware tutorial/hint bar. Fork of claude-hud by Jarrod Watts.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyderapple/claude-hub-new.git"
  },
  "homepage": "https://github.com/hyderapple/claude-hub-new",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "src/",
    "commands/",
    ".claude-plugin/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && c8 --reporter=text --reporter=lcov node --test",
    "test:update-snapshots": "UPDATE_SNAPSHOTS=1 npm test",
    "test:stdin": "npm run build && echo '{\"model\":{\"display_name\":\"Opus\"},\"context_window\":{\"current_usage\":{\"input_tokens\":45000},\"context_window_size\":200000},\"transcript_path\":\"/tmp/test.jsonl\"}' | node dist/index.js"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "hud",
    "tutorial",
    "tips"
  ],
  "author": "hyderapple",
  "contributors": [
    "Jarrod Watts (original claude-hud author)"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "typescript": "^6.0.2"
  }
}
